  -u, --user USER         create/use default user instead of root
  -m, --mount SPEC        add bind mount, e.g. /sdcard:/sdcard
  -e, --env KEY=VALUE     add environment variable
      --post-install FILE run host file inside the container after install
      --no-default-mounts skip /sdcard, /storage, /termux, /host-home defaults
