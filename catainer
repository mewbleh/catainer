  catainer flavors voidlinux
  catainer create u24 --distro ubuntu --release 24.04 --user dev
  catainer create slim --distro debian --release bookworm --variant slim
  catainer create arch --distro archlinux
  catainer create fedora --distro fedora --release 44 --variant default
  catainer create alpine --distro alpine --mount /sdcard:/sdcard
  catainer shell u24
  catainer login u24
  catainer link u24
  catainer compat u24 android-safe
  catainer doctor u24
