#!/usr/bin/env bash
set -Eeuo pipefail

VERSION="1.5.7"

CAT_HOME="${CAT_HOME:-${HOME}/.catainer}"
CONTAINERS_DIR="${CAT_HOME}/containers"
CACHE_DIR="${CAT_HOME}/cache"
TMP_DIR="${CAT_HOME}/tmp"
SHARED_DIR="${CAT_HOME}/shared"
UPDATE_CACHE="${CAT_HOME}/update-check"

DEFAULT_PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

C_RESET=""
C_BOLD=""
C_DIM=""
C_RED=""
C_GREEN=""
C_YELLOW=""
C_BLUE=""
C_MAGENTA=""
C_CYAN=""

MAIN_ARGS=()

setup_colors() {
  case "${CAT_COLOR:-auto}" in
    never) return 0 ;;
    always) ;;
    auto)
      [[ -t 1 && -z "${NO_COLOR:-}" ]] || return 0
      ;;
    *)
      [[ -t 1 && -z "${NO_COLOR:-}" ]] || return 0
      ;;
  esac

  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_MAGENTA=$'\033[35m'
  C_CYAN=$'\033[36m'
}

note() {
  printf '%bcatainer:%b %s\n' "$C_CYAN" "$C_RESET" "$*" >&2
}

warn() {
  printf '%bcatainer: warning:%b %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2
}

die() {
  printf '%bcatainer: error:%b %s\n' "$C_RED" "$C_RESET" "$*" >&2
  exit 1
}

print_logo() {
  cat <<EOF
${C_CYAN}${C_BOLD}   ______      __        _
  / ____/___ _/ /_____ _(_)___  ___  _____
 / /   / __ \`/ __/ __ \`/ / __ \\/ _ \\/ ___/
/ /___/ /_/ / /_/ /_/ / / / / /  __/ /
\\____/\\__,_/\\__/\\__,_/_/_/ /_/\\___/_/${C_RESET}

EOF
}

container_count() {
  local count

  if [[ -d "$CONTAINERS_DIR" ]]; then
    count="$(find "$CONTAINERS_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d '[:space:]')" || count="0"
    printf '%s' "${count:-0}"
  else
    printf '0'
  fi
}

print_overview() {
  print_logo
  cat <<EOF
${C_BOLD}catainer ${VERSION}${C_RESET}
Customizable proot Linux containers for Termux

${C_GREEN}Usage:${C_RESET}
  catainer create NAME --distro DISTRO [options]
  catainer shell NAME
  catainer exec NAME -- COMMAND
  catainer login NAME
  catainer link NAME
  catainer status

${C_GREEN}Setup:${C_RESET}
  catainer status                 Show host, dependency, and compatibility overview
  catainer setup                  Install Termux runtime dependencies
  catainer updates                Check for catainer updates
  catainer self-update            Update catainer from GitHub

${C_GREEN}Discover:${C_RESET}
  catainer sources                List supported distro sources
  catainer releases DISTRO        List releases for a distro
  catainer flavors DISTRO         List variants for a distro

${C_GREEN}Containers:${C_RESET}
  catainer create NAME            Create a container
  catainer ls                     List installed containers
  catainer inspect NAME           Show container configuration
  catainer shell NAME             Enter a container shell
  catainer exec NAME -- COMMAND   Run one command inside a container
  catainer login NAME             Try distro PAM/login session
  catainer link NAME              Create a direct launcher for a container
  catainer upgrade NAME           Upgrade packages inside a container
  catainer delete NAME            Delete a container

${C_GREEN}Compatibility:${C_RESET}
  catainer compat NAME android-safe
  catainer doctor NAME --run-tests

${C_GREEN}Storage:${C_RESET}
  Containers: ${CONTAINERS_DIR} (${C_BOLD}$(container_count)${C_RESET} installed)
  Cache:      ${CACHE_DIR}

Run ${C_BOLD}catainer --help${C_RESET} for all commands.
EOF
}

require_option_value() {
  local option="$1"
  local value="${2:-}"

  [[ -n "$value" ]] || die "option $option requires a value"
}

parse_top_level_args() {
  MAIN_ARGS=()

  while (($#)); do
    case "$1" in
      --)
        shift
        MAIN_ARGS=("$@")
        return 0
        ;;
      -h|--help|help|-V|--version|version)
        MAIN_ARGS=("$@")
        return 0
        ;;
      --color)
        require_option_value "$1" "${2:-}"
        CAT_COLOR="$2"
        shift 2
        ;;
      --color=*)
        CAT_COLOR="${1#*=}"
        shift
        ;;
      --no-color)
        CAT_COLOR="never"
        shift
        ;;
      --progress)
        require_option_value "$1" "${2:-}"
        CAT_PROGRESS="$2"
        shift 2
        ;;
      --progress=*)
        CAT_PROGRESS="${1#*=}"
        shift
        ;;
      --progress-mode)
        require_option_value "$1" "${2:-}"
        CAT_PROGRESS_MODE="$2"
        shift 2
        ;;
      --progress-mode=*)
        CAT_PROGRESS_MODE="${1#*=}"
        shift
        ;;
      --progress-width)
        require_option_value "$1" "${2:-}"
        CAT_PROGRESS_WIDTH="$2"
        shift 2
        ;;
      --progress-width=*)
        CAT_PROGRESS_WIDTH="${1#*=}"
        shift
        ;;
      --progress-step)
        require_option_value "$1" "${2:-}"
        CAT_PROGRESS_STEP="$2"
        shift 2
        ;;
      --progress-step=*)
        CAT_PROGRESS_STEP="${1#*=}"
        shift
        ;;
      --progress-interval)
        require_option_value "$1" "${2:-}"
        CAT_PROGRESS_INTERVAL="$2"
        shift 2
        ;;
      --progress-interval=*)
        CAT_PROGRESS_INTERVAL="${1#*=}"
        shift
        ;;
      --no-update-notify)
        CAT_UPDATE_NOTIFY="never"
        shift
        ;;
      --update-notify)
        CAT_UPDATE_NOTIFY="always"
        shift
        ;;
      --update-ttl)
        require_option_value "$1" "${2:-}"
        CAT_UPDATE_TTL="$2"
        shift 2
        ;;
      --update-ttl=*)
        CAT_UPDATE_TTL="${1#*=}"
        shift
        ;;
      --proot-no-seccomp)
        CAT_PROOT_NO_SECCOMP="always"
        shift
        ;;
      --no-proot-no-seccomp)
        CAT_PROOT_NO_SECCOMP="never"
        shift
        ;;
      --proot-assume-new-seccomp)
        CAT_PROOT_ASSUME_NEW_SECCOMP="always"
        shift
        ;;
      --no-proot-assume-new-seccomp)
        CAT_PROOT_ASSUME_NEW_SECCOMP="never"
        shift
        ;;
      --keep-ld-preload)
        CAT_PROOT_UNSET_LD_PRELOAD="never"
        shift
        ;;
      --no-proot-fake-root)
        CAT_PROOT_FAKE_ROOT="never"
        shift
        ;;
      --proot-fake-root)
        CAT_PROOT_FAKE_ROOT="always"
        shift
        ;;
      --no-proot-link2symlink)
        CAT_PROOT_LINK2SYMLINK="never"
        shift
        ;;
      --proot-link2symlink)
        CAT_PROOT_LINK2SYMLINK="always"
        shift
        ;;
      --proot-tmp-dir)
        require_option_value "$1" "${2:-}"
        CAT_PROOT_TMP_DIR="$2"
        shift 2
        ;;
      --proot-tmp-dir=*)
        CAT_PROOT_TMP_DIR="${1#*=}"
        shift
        ;;
      --plain)
        CAT_COLOR="never"
        CAT_PROGRESS="never"
        shift
        ;;
      -*)
        MAIN_ARGS=("$@")
        return 0
        ;;
      *)
        MAIN_ARGS=("$@")
        return 0
        ;;
    esac
  done
}

run_default_action() {
  print_overview
}

